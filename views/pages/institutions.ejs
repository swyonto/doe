  <style>
    .page-banner {
      background: url(/img/about/inner-header-bg.gif);
      background-position: center;
      display: flex;
      justify-content: space-between;
      color: white;
      padding: 15px 80px;
      text-align: center;
      margin-bottom: 0px;
      align-items: center;
    }

    .page-banner h1 {
      margin: 0;
      font-size: 1.4em;
      font-weight: 500;
    }

    .page-banner-img {
      height: 40px;
    }

    .breadcrumb-container {
      background-color: #f5f5f5;
      padding: 15px 0;
      margin-bottom: 30px;
      border-bottom: 1px solid #ddd;
    }

    .breadcrumb {
      margin: 0;
      padding: 0;
      background: transparent;
      font-size: 12px;
    }

    .breadcrumb a {
