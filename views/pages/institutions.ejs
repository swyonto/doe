      color: #555;
      margin-top: 0;
      margin-bottom: 20px;
      font-weight: normal;
    }

    /* Table */
    .inst-table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 30px;
    }

    .inst-table th,
    .inst-table td {
      border: 1px solid #ddd;
      padding: 10px;
      text-align: left;
      font-size: 13px;
    }

    .inst-table th {
      background-color: #f5f5f5;
      font-weight: bold;
      color: #333;
    }

    .inst-table td {
      vertical-align: top;
    }

    .inst-table tr:nth-child(even) {
      background-color: #fcfcfc;
    }

    .website-link {
      color: #0066cc;
      text-decoration: none;
      word-break: break-all;
    }

    .website-link:hover {
      text-decoration: underline;
    }

    .external-icon {
      font-size: 0.8em;
      margin-left: 3px;
      color: #888;
    }

    /* Sidebar */
    .page-sidebar {
      background: #f5f5f5;
      padding: 15px 0;
      border: 1px solid #ddd;
    }

    .page-sidebar h3 {
      background: #666;
      color: white;
      padding: 10px 15px;
      margin: -15px 0 15px 0;
      font-size: 1.1em;
    }

    .page-sidebar ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .page-sidebar li {
      border-bottom: 1px solid #ddd;
    }

    .page-sidebar li:last-child {
      border-bottom: none;
    }

    .page-sidebar a {
      color: #333;
      text-decoration: none;
      display: flex;
      align-items: center;
      font-size: 13px;
      padding: 8px 15px;
    }

    .page-sidebar a:hover {
      color: #0066cc;
      background-color: #ebebeb;
    }

    .page-sidebar a:before {
      content: "▶";
      margin-right: 8px;
      font-size: 0.6em;
      color: #888;
    }

    .last-updated {
      text-align: right;
      font-size: 11px;
      color: #888;
      margin-top: 20px;
    }
