  <script>
    document.querySelectorAll('.menu-toggle').forEach(toggle => {
      toggle.addEventListener('click', function(e) {
        e.preventDefault();
        const subMenu = this.parentElement.querySelector('.sub-menu');
        if (subMenu) {
          subMenu.classList.toggle('active');
        }
      });
    });
  </script>
