<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Right to Information Act, 2005 | Ministry of Education</title>
  <link rel="icon" type="image/x-icon" href="/favicon.png" />
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/index.css" />
  <link rel="stylesheet" href="/css/nav.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    .page-banner {
      background: url(/img/about/inner-header-bg.gif);
      background-position: center;
      display: flex;
      justify-content: space-between;
      color: white;
      padding: 15px 80px;
      text-align: center;
      margin-bottom: 0px;
      align-items: center;
    }

    .page-banner h1 {
      margin: 0;
      font-size: 1.4em;
      font-weight: 500;
    }

    .page-banner-img {
      height: 40px;
    }

    .breadcrumb-container {
      background-color: #f5f5f5;
      padding: 15px 0;
      margin-bottom: 30px;
      border-bottom: 1px solid #ddd;
    }

    .breadcrumb {
      margin: 0;
      padding: 0;
      background: transparent;
      font-size: 12px;
    }

    .breadcrumb a {
      color: #0066cc;
      text-decoration: none;
    }

    .page-content {
      padding: 0 20px;
      margin-bottom: 50px;
    }

    .page-main {
      background: white;
      padding: 20px;
    }

    .page-title {
      font-size: 1.6em;
      color: #555;
      margin-top: 0;
      margin-bottom: 20px;
      font-weight: normal;
    }

    .section-heading {
      font-size: 1.2em;
      font-weight: bold;
      color: #333;
      margin-bottom: 15px;
      margin-top: 25px;
    }

    /* PDF List */
    .pdf-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .pdf-list li {
      margin-bottom: 12px;
      display: flex;
      align-items: flex-start;
      font-size: 13px;
    }

    .pdf-list .pdf-icon {
      color: #cc0000;
      margin-right: 8px;
      margin-top: 2px;
      font-size: 1.1em;
    }

    .pdf-list .pdf-link {
      color: #0066cc;
      text-decoration: none;
      cursor: default; /* Make it look unclickable */
    }

    .pdf-list .pdf-link:hover {
      text-decoration: none; /* Prevent underline on hover */
    }

    .pdf-list .new-badge {
      background-color: #cc0000;
      color: white;
      font-size: 10px;
      padding: 2px 5px;
      border-radius: 3px;
      margin-left: 5px;
      font-weight: bold;
    }

    /* Sidebar */
    .page-sidebar {
      background: #f5f5f5;
      padding: 15px 0;
      border: 1px solid #ddd;
    }

    .page-sidebar h3 {
      background: #666;
      color: white;
      padding: 10px 15px;
      margin: -15px 0 15px 0;
      font-size: 1.1em;
    }

    .page-sidebar ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .page-sidebar li {
      border-bottom: 1px solid #ddd;
    }

    .page-sidebar li:last-child {
      border-bottom: none;
    }

    .page-sidebar a {
      color: #333;
      text-decoration: none;
      display: flex;
      align-items: center;
      font-size: 13px;
      padding: 8px 15px;
    }

    .page-sidebar a:hover {
      color: #0066cc;
      background-color: #ebebeb;
    }

    .page-sidebar a:before {
      content: "▶";
      margin-right: 8px;
      font-size: 0.6em;
      color: #888;
    }

    /* Contact Us Section */
    .contact-us {
      margin-top: 40px;
      border-top: 1px solid #eee;
      padding-top: 20px;
    }

    .contact-us h4 {
      font-size: 1.2em;
      font-weight: bold;
      color: #333;
      margin-bottom: 15px;
    }

    .contact-us p {
      font-size: 13px;
      color: #555;
      line-height: 1.6;
      margin-bottom: 10px;
    }

    .contact-us strong {
      display: block;
      color: #333;
    }

  </style>
</head>

