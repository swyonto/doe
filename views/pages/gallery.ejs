<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Photo Gallery | Ministry of Education</title>
  <link rel="icon" type="image/x-icon" href="/favicon.png" />
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/index.css" />
  <link rel="stylesheet" href="/css/nav.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    .page-banner {
      background: url(/img/about/inner-header-bg.gif);
      background-position: center;
      display: flex;
      justify-content: space-between;
      color: white;
      padding: 15px 80px;
      text-align: center;
      margin-bottom: 0px;
      align-items: center;
    }

    .page-banner h1 {
      margin: 0;
      font-size: 1.4em;
      font-weight: 500;
    }

    .page-banner-img {
      height: 40px;
    }

    .breadcrumb-container {
      background-color: #f5f5f5;
      padding: 15px 0;
      margin-bottom: 30px;
      border-bottom: 1px solid #ddd;
    }

    .breadcrumb {
      margin: 0;
      padding: 0;
      background: transparent;
      font-size: 12px;
    }

    .breadcrumb a {
      color: #0066cc;
      text-decoration: none;
    }

    .page-content {
      padding: 0 20px;
      margin-bottom: 50px;
      min-height: 300px;
    }

    .page-main {
      background: white;
      padding: 20px;
    }

    .no-data-msg {
      font-size: 13px;
      color: #555;
      margin-top: 10px;
    }

    /* Sidebar */
    .page-sidebar {
      background: #f5f5f5;
      padding: 15px 0;
      border: 1px solid #ddd;
    }

    .page-sidebar h3 {
      background: #666;
      color: white;
      padding: 10px 15px;
      margin: -15px 0 15px 0;
      font-size: 1.1em;
    }

    .page-sidebar ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .page-sidebar li {
      border-bottom: 1px solid #ddd;
    }

    .page-sidebar li:last-child {
      border-bottom: none;
    }

    .page-sidebar a {
      color: #333;
      text-decoration: none;
      display: flex;
      align-items: center;
      font-size: 13px;
      padding: 8px 15px;
    }

    .page-sidebar a:hover {
      color: #0066cc;
      background-color: #ebebeb;
    }

    .page-sidebar a:before {
      content: "▶";
      margin-right: 8px;
      font-size: 0.6em;
      color: #888;
    }
    
    .external-icon {
      font-size: 0.8em;
      margin-left: 3px;
      color: #888;
    }
  </style>
</head>

<body>
  <%- include('../partials/nav') %>

  <div class="page-banner">
    <h1>Photo Gallery</h1>
    <img src="/img/about/banner-right.jpg" alt="Banner" class="page-banner-img">
  </div>

  <div class="breadcrumb-container" style="margin-bottom: 0;">
    <div class="container" style="width: 100%; padding: 15px 30px;">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li><a href="#">Multimedia<i class="bi bi-box-arrow-up-right external-icon"></i></a></li>
        <li><a href="/gallery">Photo Gallery</a></li>
        <li class="active">Photo Gallery</li>
      </ol>
    </div>
  </div>

  <div class="page-content" style="padding: 20px 30px;">
    <div class="row">
      <!-- Main Content -->
      <div class="col-md-9" style="padding-left: 0;">
        <div class="page-main" style="padding-top: 0; padding-left: 0;">
          
          <div class="no-data-msg">
            No Data Available
          </div>

        </div>
      </div>

      <!-- Sidebar -->
      <div class="col-md-3" style="padding-right: 0;">
        <div class="page-sidebar">
          <h3>Multimedia</h3>
          <ul>
            <li><a href="#">Covid-19 Campaign</a></li>
            <li><a href="https://www.youtube.com/user/HRDMinistry/videos" target="_blank">YouTube Channel<i class="bi bi-box-arrow-up-right external-icon"></i></a></li>
            <li><a href="/audios">Audio</a></li>
            <li><a href="/gallery">Photo Gallery</a></li>
            <li><a href="#">Archived Photo Gallery</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
</body>

</html>
