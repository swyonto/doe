      color: white;
      padding: 10px;
      margin: -20px -20px 20px -20px;
      font-size: 1.1em;
    }

    .page-sidebar ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .page-sidebar li {
      border-bottom: 1px solid #ddd;
      padding: 12px 0;
    }

    .page-sidebar li:last-child {
      border-bottom: none;
    }

    .page-sidebar a {
      color: #333;
      text-decoration: none;
      display: flex;
      align-items: center;
    }

    .page-sidebar a:hover {
      color: #0066cc;
    }

    .page-sidebar a:before {
      content: "▶";
      margin-right: 10px;
      font-size: 0.8em;
    }

    .section-title {
      font-size: 1.6em;
      margin-bottom: 25px;
      color: #555;
    }

    .subsection-title {
