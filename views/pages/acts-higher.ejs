  <style>
    .page-banner {
      background: url(/img/about/inner-header-bg.gif);
      max-width: 100vw;
      overflow-x: hidden;
      background-position: center;
      display: flex;
      justify-content: space-between;
      color: white;
      padding: 0px 80px;
      text-align: center;
      margin-bottom: 30px;
