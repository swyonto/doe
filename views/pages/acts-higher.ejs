      content: "▶";
      color: #555;
      margin-right: 8px;
      font-size: 0.8em;
      margin-top: 4px;
    }

    /* Make links look blue but not clickable */
    .charter-links a {
      color: #0066cc;
      text-decoration: none;
      font-size: 14px;
      cursor: default;
      /* No pointer cursor */
      pointer-events: none;
      /* Not clickable */
      display: inline-block;
    }

    .charter-links a:hover {
      text-decoration: none;
    }
