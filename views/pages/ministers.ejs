<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ministers | Ministry of Education</title>
  <link rel="icon" type="image/x-icon" href="/favicon.png" />
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" />
  <link rel="stylesheet" href="/css/index.css" />
  <link rel="stylesheet" href="/css/nav.css">
  <link rel="stylesheet" href="/css/footer.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    .page-banner {
      background: #005073;
      background-position: center;
      display: flex;
      justify-content: space-between;
      color: white;
      padding: 15px 80px;
      text-align: center;
      margin-bottom: 0px;
      align-items: center;
    }

    .page-banner h1 {
      margin: 0;
      font-size: 1.4em;
      font-weight: 500;
    }
    
    .page-banner-img {
      height: 40px;
    }

    .breadcrumb-container {
      background-color: #f5f5f5;
      padding: 15px 0;
      margin-bottom: 30px;
      border-bottom: 1px solid #ddd;
    }

    .breadcrumb {
      margin: 0;
      padding: 0;
      background: transparent;
      font-size: 12px;
    }

    .breadcrumb a {
      color: #0066cc;
      text-decoration: none;
    }

    .page-content {
      padding: 0 20px;
      margin-bottom: 50px;
    }

    .page-main {
      background: white;
      padding: 20px;
    }

    /* Ministers Grid */
    .minister-card {
      text-align: center;
      margin-bottom: 5px;
    }
    
    .minister-img-container {
      display: inline-block;
      padding: 3px;
      border: 1px solid #ddd;
      margin-bottom: 10px;
    }

    .minister-img-container img {
      width: 60px;
      height: 75px;
      object-fit: cover;
    }

    .minister-name {
      font-weight: bold;
      color: #333;
      margin-bottom: 3px;
      font-size: 13px;
    }

    .minister-title {
      color: #666;
      font-size: 12px;
      margin-bottom: 2px;
    }

    .minister-gov {
      color: #888;
      font-size: 11px;
    }

    .divider {
      border-top: 1px dotted #ccc;
      margin: 5px 0;
    }

    /* Sidebar */
    .page-sidebar {
      background: #f0f0f0;
      padding: 20px;
      border-radius: 4px;
    }

    .page-sidebar h3 {
      background: #666;
      color: white;
      padding: 10px;
      margin: -20px -20px 20px -20px;
      font-size: 1.1em;
    }

    .page-sidebar ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .page-sidebar li {
      border-bottom: 1px solid #ddd;
      padding: 10px 0;
    }

    .page-sidebar li:last-child {
      border-bottom: none;
    }

    .page-sidebar a {
      color: #333;
      text-decoration: none;
      display: flex;
      align-items: center;
      font-size: 13px;
    }

    .page-sidebar a:hover {
      color: #0066cc;
    }

    .page-sidebar a:before {
      content: "▶";
      margin-right: 8px;
      font-size: 0.7em;
      color: #888;
    }

    .last-updated {
      text-align: right;
      font-size: 11px;
      color: #888;
      margin-top: 20px;
    }
  </style>
</head>

<body>
  <%- include('../partials/nav') %>

  <div class="page-banner">
    <h1>Ministers</h1>
    <img src="/img/about/banner-right.jpg" alt="Parliament" class="page-banner-img">
  </div>

  <div class="breadcrumb-container">
    <div class="container">
      <ol class="breadcrumb">
        <li><a href="/">Home</a></li>
        <li><a href="#">About Us</a></li>
        <li><a href="/minister-page">Who's Who</a></li>
        <li class="active">Ministers</li>
      </ol>
    </div>
  </div>

  <div class="page-content">
    <div class="container">
      <div class="row">
        <!-- Main Content -->
        <div class="col-md-9">
          <div class="page-main">
            
            <!-- Top Minister -->
            <div class="row">
              <div class="col-md-12">
                <div class="minister-card">
                  <div class="minister-img-container">
                    <img src="https://www.education.gov.in/sites/education.gov.in/themes/nexus/images/whoswho/rpn_whoswho.jpg" alt="Shri Dharmendra Pradhan">
                  </div>
                  <div class="minister-name">Shri Dharmendra Pradhan</div>
                  <div class="minister-title">Minister of Education</div>
                  <div class="minister-gov">Government of India</div>
                </div>
              </div>
            </div>

            <div class="divider"></div>

            <!-- Bottom Ministers -->
            <div class="row">
              <div class="col-md-6">
                <div class="minister-card">
                  <div class="minister-img-container">
                    <img src="https://www.education.gov.in/sites/education.gov.in/themes/nexus/images/whoswho/Sukanta_Majumdar.jpg" alt="Dr. Sukanta Majumdar">
                  </div>
                  <div class="minister-name">Dr. Sukanta Majumdar</div>
                  <div class="minister-title">Minister of State for Education</div>
                  <div class="minister-gov">Government of India</div>
                </div>
              </div>
              <div class="col-md-6">
                <div class="minister-card">
                  <div class="minister-img-container">
                    <img src="https://www.education.gov.in/sites/education.gov.in/themes/nexus/images/whoswho/Jayant_Chaudhary.jpg" alt="Shri Jayant Chaudhary">
                  </div>
                  <div class="minister-name">Shri Jayant Chaudhary</div>
                  <div class="minister-title">Minister of State for Education</div>
                  <div class="minister-gov">Government of India</div>
                </div>
              </div>
            </div>

            <div class="last-updated">
              Last Updated by admin on Tuesday, 11 June 2024 - 6:19pm
            </div>

          </div>
        </div>

        <!-- Sidebar -->
        <div class="col-md-3">
          <div class="page-sidebar">
            <h3>Who is Who</h3>
            <ul>
              <li>
                <a href="/minister-page">Ministers</a>
                <ul style="padding-left: 15px; margin-top: 10px; border-bottom: none;">
                   <li style="border-bottom: none; padding-bottom: 0;"><a href="#">Ministers Office</a></li>
                </ul>
              </li>
              <li><a href="#">Higher Education</a></li>
              <li><a href="#">School Education & Literacy</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%- include('../partials/footer') %>

  <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/js/bootstrap.min.js"></script>
</body>

</html>
